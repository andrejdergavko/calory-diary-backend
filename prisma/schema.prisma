// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output  = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"

}

enum Role {
  USER
  ADMIN
}

model User {
  id              Int       @default(autoincrement()) @id
  email           String    @unique
  name            String
  hashedPassword  String
  role            Role      @default(USER)
  
}

model Category {
  id       Int       @default(autoincrement()) @id
  name     String    @unique
}

